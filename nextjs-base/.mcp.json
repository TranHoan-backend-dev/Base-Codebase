{
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "./"
            ],
            "description": "Cho phép AI đọc và ghi file trong dự án"
        },
        "web-search": {
            "command": "sh",
            "args": [
                "-c",
                "export $(grep -v '^#' .env | xargs) && npx -y @modelcontextprotocol/server-google-search"
            ],
            "description": "Tạm thời vô hiệu hóa cho đến khi có API Key. Giữ nguyên để bảo toàn cấu trúc."
        },
        "nextjs-docs-fetcher": {
            "command": "npx",
            "args": [
                "-y",
                "@mcp-server/fetch",
                "https://nextjs.org/docs"
            ]
        },
        "heroui-docs": {
            "command": "npx",
            "args": [
                "-y",
                "@mcp-server/fetch",
                "https://heroui.com/docs/react/"
            ]
        },
        "project_rules": [
            "./.claude/rules/*.md",
            "./.claude/agents/*.md"
        ],
        "external_skills_path": "./.agent/",
        "behavior": {
            "lazy_load_external_agents": true,
            "primary_context_source": ".claude"
        }
    }
}
