{
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "./"
            ],
            "description": "Cho phép AI đọc và ghi file trong dự án Backend"
        },
        "web-search": {
            "command": "sh",
            "args": [
                "-c",
                "export $(grep -v '^#' ../.env | xargs) && npx -y @modelcontextprotocol/server-google-search"
            ],
            "description": "Tìm kiếm web với API Key từ Root"
        },
        "spring-boot-docs-fetcher": {
            "command": "npx",
            "args": [
                "-y",
                "@mcp-server/fetch",
                "https://docs.spring.io/spring-boot/docs/current/reference/htmlsingle/"
            ],
            "description": "Fetch tài liệu chính thức của Spring Boot 3"
        },
        "postgresql-docs-fetcher": {
            "command": "npx",
            "args": [
                "-y",
                "@mcp-server/fetch",
                "https://www.postgresql.org/docs/current/index.html"
            ],
            "description": "Fetch tài liệu chính thức của PostgreSQL"
        },
        "project_rules": [
            "./.claude/rules/*.md",
            "./.claude/context/*.md",
            "./.claude/agents/*.md"
        ],
        "behavior": {
            "lazy_load_external_agents": true,
            "primary_context_source": ".claude"
        }
    }
}
