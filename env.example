# ==============================================================================
# BASE-CODEBASE ENVIRONMENT VARIABLES EXAMPLE
# Copy file này thành ".env" và cập nhật các giá trị phù hợp với môi trường của bạn.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Cấu hình Server (Server Configuration)
# ------------------------------------------------------------------------------
PORT=9003
SERVER_SERVLET_CONTEXT_PATH=/api/v1

# ------------------------------------------------------------------------------
# 2. Cấu hình Cổng kết nối Frontend (CORS)
# ------------------------------------------------------------------------------
WEB_FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 3. Cấu hình Dual Datasource (SQL Database - JPA)
#    - business: DB chứa các entity nghiệp vụ (thường mỗi service định nghĩa riêng)
#    - system:   DB chứa các entity kỹ thuật (OutboxEvent, SystemSetting, DynamicGridConfig)
# ------------------------------------------------------------------------------
SPRING_DATASOURCE_BUSINESS_URL=jdbc:postgresql://localhost:5432/db_business
SPRING_DATASOURCE_BUSINESS_USERNAME=postgres
SPRING_DATASOURCE_BUSINESS_PASSWORD=postgres

SPRING_DATASOURCE_SYSTEM_URL=jdbc:postgresql://localhost:5432/db_system
SPRING_DATASOURCE_SYSTEM_USERNAME=postgres
SPRING_DATASOURCE_SYSTEM_PASSWORD=postgres

# ------------------------------------------------------------------------------
# 4. Cấu hình Redis dùng chung (Shared Redis Caching & Locks)
# ------------------------------------------------------------------------------
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# 5. Cấu hình Elasticsearch (Log & Search Indexing)
# ------------------------------------------------------------------------------
SPRING_ELASTICSEARCH_URIS=http://localhost:9200
SPRING_ELASTICSEARCH_USERNAME=elastic
SPRING_ELASTICSEARCH_PASSWORD=password

# ------------------------------------------------------------------------------
# 6. Cấu hình Dynamic Event Bus (Kafka / RabbitMQ / None)
# ------------------------------------------------------------------------------
COMMON_EVENT_BUS_TYPE=none # Giá trị hỗ trợ: kafka | rabbitmq | none

# --- Cấu hình nếu sử dụng Kafka ---
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SPRING_KAFKA_CONSUMER_GROUP_ID=common-group

# --- Cấu hình nếu sử dụng RabbitMQ ---
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
RABBIT_MQ_CONFIG_EXCHANGE_NAME=event_exchange
RABBIT_MQ_CONFIG_QUEUE=main-service-queue

# ------------------------------------------------------------------------------
# 7. Cấu hình API Documentation (Swagger / OpenAPI)
# ------------------------------------------------------------------------------
SPRINGDOC_API_DOCS_PATH=/v3/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui/index.html
